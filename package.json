{
  "name": "online-mba-landing",
  "version": "1.0.0",
  "description": "Modular SSG Landing Page",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./_site/css/style.css --minify",
    "build:html": "eleventy",
    "build": "npm run build:css && npm run build:html",
    "watch:css": "tailwindcss -i ./src/input.css -o ./_site/css/style.css --watch",
    "watch:html": "eleventy --serve",
    "dev": "npm-run-all --parallel watch:*"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.4.1"
  }
}
